---
interface Props {
  name?: string;
  level?: string;
  summary?: string;
  keywords?: string[];
  class?: string;
}
const { name, level, summary, keywords, class: className } = Astro.props;
---

<div class:list={["Card", className]}>
  <h1 class="font-bold text-xl">{name}</h1>
  <ul class="columns-2 text-sm list-disc list-inside">
    {keywords.map((keyword) => <li>{keyword}</li>)}
  </ul>
</div>
